# IronProse CLI Configuration
# Copy to .env and fill in your values

# API base URL (default: https://api.ironprose.com)
# IRONPROSE_API_URL=https://api.ironprose.com

# API key for authenticated access (optional, free tier: 5000 words)
# IRONPROSE_API_KEY=your-api-key-here

# Workspace directory for MCP file tools (required for ironprose mcp)
# IRONPROSE_WORKSPACE=/path/to/your/manuscript

# Log level (default: info)
# RUST_LOG=info
